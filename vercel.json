{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30,
      "includeFiles": "backend/dist/**,node_modules/.prisma/**,node_modules/@prisma/client/**"
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/chat-stream", "destination": "/api/[...path]" },
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/api/contact/project", "destination": "/api/contact/project" },
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
