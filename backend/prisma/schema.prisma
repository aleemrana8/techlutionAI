generator client {
  provider      = "prisma-client-js"
  output        = "../../node_modules/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  name         String
  role         Role      @default(CLIENT)
  isActive     Boolean   @default(true)
  refreshToken String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agents       Agent[]
  projects     Project[]

  @@map("users")
}

model Project {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  shortDescription String
  fullDescription  String
  category         ProjectCategory
  features         String[]
  workflowSteps    Json[]
  benefits         String[]
  images           String[]
  status           ProjectStatus   @default(DRAFT)
  tags             String[]
  techStack        String[]
  durationWeeks    Int?
  deadline         DateTime?
  createdById      String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  files            File[]
  createdBy        User            @relation(fields: [createdById], references: [id])
  assignments      ProjectAssignment[]
  tasks            Task[]

  @@map("projects")
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message   String
  type      LeadType   @default(INQUIRY)
  budget    String?
  timeline  String?
  status    LeadStatus @default(NEW)
  response  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("leads")
}

model Agent {
  id          String     @id @default(cuid())
  name        String
  type        AgentType
  description String?
  config      Json       @default("{}")
  isActive    Boolean    @default(true)
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  workflows   Workflow[]

  @@map("agents")
}

model Patient {
  id                  String        @id @default(cuid())
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gender              String
  phone               String?
  email               String?
  address             String?
  city                String?
  state               String?
  zipCode             String?
  medicalRecordNumber String        @unique
  insuranceId         String?
  insuranceProvider   String?
  groupNumber         String?
  memberId            String?
  notes               String?
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  appointments        Appointment[]
  billings            Billing[]

  @@map("patients")
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  appointmentDate DateTime
  appointmentTime String
  type            String
  provider        String?
  location        String?
  status          AppointmentStatus @default(SCHEDULED)
  reasonForVisit  String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  patient         Patient           @relation(fields: [patientId], references: [id])
  billings        Billing[]

  @@map("appointments")
}

model Billing {
  id               String        @id @default(cuid())
  patientId        String
  appointmentId    String?
  dateOfService    DateTime
  chargeAmount     Float
  paidAmount       Float         @default(0)
  adjustmentAmount Float         @default(0)
  balanceDue       Float
  status           BillingStatus @default(PENDING)
  icdCodes         String[]
  cptCodes         String[]
  insuranceId      String?
  claimNumber      String?
  eobReceived      Boolean       @default(false)
  eobDate          DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  appointment      Appointment?  @relation(fields: [appointmentId], references: [id])
  patient          Patient       @relation(fields: [patientId], references: [id])
  denials          Denial[]

  @@map("billings")
}

model Denial {
  id          String       @id @default(cuid())
  billingId   String
  denialCode  String
  reason      String
  denialDate  DateTime
  status      DenialStatus @default(OPEN)
  appealNotes String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  billing     Billing      @relation(fields: [billingId], references: [id])

  @@map("denials")
}

model Workflow {
  id          String          @id @default(cuid())
  name        String
  description String?
  trigger     WorkflowTrigger @default(MANUAL)
  steps       Json[]
  status      WorkflowStatus  @default(ACTIVE)
  agentId     String?
  webhookUrl  String?
  schedule    String?
  lastRunAt   DateTime?
  runCount    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  logs        WorkflowLog[]
  agent       Agent?          @relation(fields: [agentId], references: [id])

  @@map("workflows")
}

model WorkflowLog {
  id          String   @id @default(cuid())
  workflowId  String
  status      String
  input       Json?
  output      Json?
  error       String?
  durationMs  Int?
  triggeredBy String?
  createdAt   DateTime @default(now())
  workflow    Workflow @relation(fields: [workflowId], references: [id])

  @@map("workflow_logs")
}

model File {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  storagePath  String
  entityType   String?
  entityId     String?
  projectId    String?
  uploadedAt   DateTime @default(now())
  project      Project? @relation(fields: [projectId], references: [id])

  @@map("files")
}

model Visitor {
  id           String        @id @default(cuid())
  name         String?
  ipAddress    String?
  device       VisitorDevice @default(OTHER)
  browser      String?
  os           String?
  page         String?
  pagesVisited String[]      @default([])
  referrer     String?
  country      String?
  city         String?
  sessionId    String?
  timeSpent    Int?          @default(0)
  summary      String?
  createdAt    DateTime      @default(now())

  @@map("visitors")
}

model Client {
  id        String       @id @default(cuid())
  name      String
  email     String       @unique
  phone     String?
  company   String?
  industry  String?
  status    ClientStatus @default(PROSPECT)
  notes     String?
  projects  Int          @default(0)
  revenue   Float        @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  proposals Proposal[]
  whatsappContacts WhatsAppContact[]

  @@map("clients")
}

model Proposal {
  id          String         @id @default(cuid())
  clientId    String
  title       String
  description String
  budget      Float          @default(0)
  currency    String         @default("USD")
  timeline    String?
  status      ProposalStatus @default(PENDING)
  projectRef  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("proposals")
}

model Employee {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  phone      String?
  role       String
  department String
  skills     String[]       @default([])
  status     EmployeeStatus @default(ACTIVE)
  workload   Int            @default(0)
  salary     Float?
  isFounder  Boolean        @default(false)
  joinDate   DateTime       @default(now())
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  assignments ProjectAssignment[]
  shares      ProjectShare[]
  tasks       Task[]

  @@map("employees")
}

model Finance {
  id          String      @id @default(cuid())
  type        FinanceType
  amount      Float
  description String
  category    String?
  projectRef  String?
  received    Boolean     @default(true)
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("finances")
}

model AdminUser {
  id           String        @id @default(cuid())
  username     String        @unique
  email        String        @unique
  passwordHash String
  name         String
  role         AdminRole     @default(SUPPORT)
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  logs         ActivityLog[]

  @@map("admin_users")
}

model ActivityLog {
  id          String     @id @default(cuid())
  action      String
  entity      String?
  entityId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  adminUserId String?
  createdAt   DateTime   @default(now())
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  metric    String
  value     Float
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([metric, date])
  @@map("analytics_snapshots")
}

// ─── Project Assignment ─────────────────────────────────────────────────────

model ProjectAssignment {
  id           String   @id @default(cuid())
  projectRef   String
  employeeId   String
  roleInProject String?
  assignedAt   DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project      Project  @relation(fields: [projectRef], references: [id], onDelete: Cascade)

  @@unique([projectRef, employeeId])
  @@index([projectRef])
  @@index([employeeId])
  @@map("project_assignments")
}

// ─── Tasks ──────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    Employee?    @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@map("tasks")
}

// ─── Project Finance (Cost Sharing) ─────────────────────────────────────────

model ProjectFinance {
  id              String   @id @default(cuid())
  projectRef      String   @unique
  totalAmount     Float
  currency        String   @default("USD")
  fiverrFeePercent Float   @default(0)
  zakatEnabled    Boolean  @default(false)
  zakatPercent    Float    @default(2.5)
  otherCosts      Json     @default("[]")
  totalDeductions Float    @default(0)
  netAmount       Float    @default(0)
  sharePerPerson  Float    @default(0)
  totalMembers    Int      @default(0)
  founderIncluded Boolean  @default(true)
  calculatedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  shares          ProjectShare[]

  @@index([projectRef])
  @@map("project_finances")
}

// ─── Project Share Distribution ─────────────────────────────────────────────

model ProjectShare {
  id             String        @id @default(cuid())
  projectFinanceId String
  employeeId     String
  shareAmount    Float
  paymentStatus  PaymentStatus @default(PENDING)
  notified       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  projectFinance ProjectFinance @relation(fields: [projectFinanceId], references: [id], onDelete: Cascade)
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectFinanceId, employeeId])
  @@index([projectFinanceId])
  @@index([employeeId])
  @@map("project_shares")
}

// ─── Email Log ──────────────────────────────────────────────────────────────

model EmailLog {
  id         String      @id @default(cuid())
  to         String
  subject    String
  type       String
  projectRef String?
  status     EmailStatus @default(SENT)
  error      String?
  createdAt  DateTime    @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("email_logs")
}

// ─── WhatsApp CRM ───────────────────────────────────────────────────────────

model WhatsAppContact {
  id             String               @id @default(cuid())
  name           String?
  phone          String               @unique
  linkedClientId String?
  linkedClient   Client?              @relation(fields: [linkedClientId], references: [id])
  tags           WhatsAppContactTag[] @default([LEAD])
  notes          String?
  lastMessageAt  DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  messages       WhatsAppMessage[]
  conversations  WhatsAppConversation[]

  @@index([phone])
  @@index([linkedClientId])
  @@map("whatsapp_contacts")
}

model WhatsAppMessage {
  id             String              @id @default(cuid())
  contactId      String
  contact        WhatsAppContact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   WhatsAppConversation? @relation(fields: [conversationId], references: [id])
  direction      MessageDirection
  body           String
  twilioSid      String?
  status         WhatsAppMsgStatus   @default(SENT)
  createdAt      DateTime            @default(now())

  @@index([contactId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

model WhatsAppConversation {
  id        String             @id @default(cuid())
  contactId String
  contact   WhatsAppContact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status    ConversationStatus @default(OPEN)
  closedAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  messages  WhatsAppMessage[]

  @@index([contactId])
  @@index([status])
  @@map("whatsapp_conversations")
}

model WhatsAppLog {
  id        String            @id @default(cuid())
  to        String
  body      String
  twilioSid String?
  status    WhatsAppMsgStatus @default(SENT)
  error     String?
  trigger   String?
  createdAt DateTime          @default(now())

  @@index([createdAt])
  @@map("whatsapp_logs")
}

enum WhatsAppContactTag {
  LEAD
  CLIENT
  HOT
  COLD
  VIP
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum WhatsAppMsgStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum EmailStatus {
  SENT
  FAILED
}

enum Role {
  ADMIN
  CLIENT
  STAFF
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProjectCategory {
  HEALTHCARE
  AI_ML
  AUTOMATION
  COMPUTER_VISION
  DEVOPS_CLOUD
  DATA_PIPELINES
  WEB_BACKEND
  OTHER
}

enum LeadType {
  INQUIRY
  PROPOSAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  RESPONDED
  IGNORED
  CLOSED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  STARTED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BillingStatus {
  PENDING
  SUBMITTED
  PAID
  PARTIALLY_PAID
  DENIED
  VOIDED
}

enum DenialStatus {
  OPEN
  APPEALED
  RESOLVED
  WRITTEN_OFF
}

enum WorkflowStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum WorkflowTrigger {
  MANUAL
  WEBHOOK
  SCHEDULE
  EVENT
}

enum AgentType {
  LLM
  RPA
  DATA_PIPELINE
  NOTIFICATION
  CUSTOM
}

enum VisitorDevice {
  DESKTOP
  MOBILE
  TABLET
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum FinanceType {
  INCOME
  EXPENSE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  HR
  FINANCE
  MANAGER
  SUPPORT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
